# Nginx 反向代理示例（Legal_AI）
# 与 deploy/docker-compose.yml 配合：请在仓库根目录 Legal_AI/ 下执行 compose，
# 使卷路径 ./deploy/nginx.conf.example 能正确挂载。
#
# 路由约定：
#   /      → Next.js（frontend:3000）
#   /api/  → FastAPI（backend:8000），前缀 /api 在转发时剥离（见 proxy_pass 尾部 /）

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream legal_ai_frontend {
    server frontend:3000;
}

upstream legal_ai_backend {
    server backend:8000;
}

server {
    listen 80;
    server_name _;

    client_max_body_size 100m;

    # API：同域 /api → 后端根路径（需设置 NEXT_PUBLIC_API_BASE_URL=/api）
    location /api/ {
        proxy_pass http://legal_ai_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 流式 / SSE：避免响应被整块缓冲
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        proxy_set_header X-Accel-Buffering no;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location / {
        proxy_pass http://legal_ai_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

