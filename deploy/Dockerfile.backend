# Backend API — build from repository root (Legal_AI/), not from deploy/.
# docker compose -f deploy/docker-compose.yml build backend
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-server.txt .
RUN pip install --no-cache-dir -U pip \
    && pip install --no-cache-dir -r requirements-server.txt

COPY api ./api
COPY auth ./auth
COPY chat_store ./chat_store
COPY config ./config
COPY law_spider ./law_spider
COPY new_feature_qwen_kb ./new_feature_qwen_kb
COPY services ./services
COPY parsers ./parsers
COPY models ./models
COPY ingestion ./ingestion
COPY agents ./agents
COPY mcp_server ./mcp_server
COPY kb_upload_store ./kb_upload_store
COPY scripts ./scripts

RUN mkdir -p /app/data /app/logs

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
