## DashScope / 百炼（Model Studio）
# 建议通过环境变量注入，勿提交真实密钥到仓库。

# 必填：DashScope API Key
DASHSCOPE_API_KEY=

# 可选：OpenAI-compatible mode base url（仅在你使用 qwen* 兼容模式时需要）
DASHSCOPE_BASE_URL=
# 推理模型（两种写法二选一）
# 2) 调用智能体应用：把模型名写成 app:APP_ID
REASONING_MODEL_NAME=app:YOUR_APP_ID

# 温度（可选）
REASONING_TEMPERATURE=0.3

## Farui（官方签名检索 API，仅法规检索用）
FARUI_ACCESS_KEY_ID=
FARUI_ACCESS_KEY_SECRET=
FARUI_WORKSPACE_ID=
FARUI_HOST=farui.cn-beijing.aliyuncs.com
FARUI_TEMPERATURE=0.01
FARUI_TIMEOUT_SECONDS=20

## Bailian 知识库（可选）
BAILIAN_WORKSPACE_ID=
BAILIAN_INDEX_ID=
BAILIAN_BASE_URL=https://bailian.aliyuncs.com
BAILIAN_TIMEOUT_SECONDS=25
