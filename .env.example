## DashScope / 百炼（Model Studio）

# 必填：DashScope API Key，用于调用 Qwen（请替换为你的真实密钥，勿提交到仓库）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 可选：OpenAI-compatible API base
# 不填时，代码默认使用 DashScope 兼容模式地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 推理模型
REASONING_MODEL_NAME=qwen-plus
NEW_QWEN_MODEL_NAME=qwen-plus
REASONING_TEMPERATURE=0.3

## 阿里云 RAM 子账号 AK/SK，用于百炼知识库 Retrieve（请替换为占位符以外的真实值，勿提交）
ALIBABA_CLOUD_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-aliyun-access-key-secret

## 百炼知识库
BAILIAN_WORKSPACE_ID=your-bailian-workspace-id
BAILIAN_INDEX_ID=your-bailian-index-id

# 注意：当前代码读取的是 BAILIAN_ENDPOINT，不是 BAILIAN_BASE_URL
BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com

BAILIAN_TIMEOUT_SECONDS=25
BAILIAN_RERANK_TOP_N=6

## RAG 知识库后端（显式开关，不会在百炼失败后自动切到本地）
# bailian：正式环境，使用阿里云百炼 Retrieve（需配置上文 AK/SK 与 BAILIAN_*）
# local：仅开发测试，读取本地 JSON（LOCAL_KB_PATH），不调用百炼
RAG_BACKEND=bailian
LOCAL_KB_PATH=data/dev_law_chunks.json

## 文本推理后端（显式开关，不会在 DashScope 失败后自动切到 Ollama）
# dashscope：正式环境，DashScope OpenAI 兼容模式（需 DASHSCOPE_API_KEY）
# ollama：本地开发，经 Ollama OpenAI 兼容 API（chat.completions）
MODEL_BACKEND=dashscope
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
LOCAL_MODEL_NAME=qwen2.5:7b
